# WinOS — environment variable reference
# Copy this file to .env and fill in values for local development.
# Never commit .env — it is gitignored.
# Production values are configured in the AWS Amplify console, not here.

# ── Database ──────────────────────────────────────────────────────────────────
# Start the local dev server first: npm run db:restart
DATABASE_URL=
# Dev only — used by Prisma for shadow database during migrations
SHADOW_DATABASE_URL=

# ── Auth.js v5 ────────────────────────────────────────────────────────────────
# Generate a value with: openssl rand -base64 32
AUTH_SECRET=

# ── SMTP (Zoho Mail) ─────────────────────────────────────────────────────────
# Required in production. In development, when SMTP_HOST is unset, OTP codes
# are printed to the server console instead of being emailed.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# Optional — defaults to: WinOS <noreply@eagleeyedigital.io>
SMTP_FROM=
